# Get these from https://developer.spotify.com/dashboard
# Create an app, then copy Client ID and Client Secret
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Optional: limit playlist search results (default 50)
# MAX_PLAYLISTS_TO_CHECK=100

# Optional: YouTube Data API v3 key — if set, YouTube search uses the official API.
# Without it, the app uses the youtube-search package (no Google account needed).
# https://console.cloud.google.com/apis/credentials
# YOUTUBE_API_KEY=your_youtube_api_key_here
