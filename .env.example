# Get these from https://developer.spotify.com/dashboard
# Create an app, then copy Client ID and Client Secret
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Optional: limit playlist search results (default 50)
# MAX_PLAYLISTS_TO_CHECK=100

# Optional: YouTube Data API v3 key — if set, YouTube search uses the official API.
# Without it, the app uses the youtube-search package (no Google account needed).
# https://console.cloud.google.com/apis/credentials
# YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: Google Custom Search – adds Google results to the Global tab.
# Free tier: 100 queries/day. https://developers.google.com/custom-search/v1/introduction
# 1. Get an API key: https://console.cloud.google.com/apis/credentials
# 2. Create a Custom Search Engine: https://programmablesearchengine.google.com/
#    (enable "Search the entire web")
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_CSE_ID=your_custom_search_engine_id_here
